--!strict
local UILibrary = {}

local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")

-- Cài đặt chung
local DEFAULT_TWEEN_TIME = 0.2
local DEFAULT_COLOR_SCHEME = {
	Primary = Color3.fromRGB(88, 101, 242),
	PrimaryDark = Color3.fromRGB(71, 82, 196),
	Background = Color3.fromRGB(30, 30, 36),
	Surface = Color3.fromRGB(40, 40, 46),
	SurfaceLight = Color3.fromRGB(50, 50, 56),
	Text = Color3.fromRGB(255, 255, 255),
	TextSecondary = Color3.fromRGB(160, 160, 170),
	Danger = Color3.fromRGB(237, 66, 69),
	Success = Color3.fromRGB(59, 165, 93),
}

-- Tạo gradient
local function applyGradient(instance, color1, color2, direction)
	local gradient = Instance.new("UIGradient")
	gradient.Color = ColorSequence.new{
		ColorSequenceKeypoint.new(0, color1),
		ColorSequenceKeypoint.new(1, color2),
	}
	if direction == "horizontal" then
		gradient.Rotation = 0
	elseif direction == "vertical" then
		gradient.Rotation = 90
	elseif direction == "diagonal" then
		gradient.Rotation = 45
	end
	gradient.Parent = instance
	return gradient
end

-- Tạo shadow (bóng đổ)
local function addShadow(instance, size, transparency)
	local shadow = Instance.new("ImageLabel")
	shadow.Name = "Shadow"
	shadow.AnchorPoint = Vector2.new(0.5, 0.5)
	shadow.BackgroundTransparency = 1
	shadow.Image = "rbxassetid://1316045215"
	shadow.ImageColor3 = Color3.new(0, 0, 0)
	shadow.ImageTransparency = transparency or 0.6
	shadow.ScaleType = Enum.ScaleType.Slice
	shadow.SliceCenter = Rect.new(8, 8, 8, 8)
	shadow.Size = UDim2.fromScale(1, 1) + UDim2.fromOffset(size or 16, size or 16)
	shadow.Position = UDim2.fromScale(0.5, 0.5)
	shadow.ZIndex = instance.ZIndex - 1
	shadow.Parent = instance
end

-- Tạo frame bo góc + gradient nền
local function createStyledFrame(parent, name, size, position, color, transparent)
	local frame = Instance.new("Frame")
	frame.Name = name
	frame.Size = size
	frame.Position = position
	frame.BackgroundColor3 = color or DEFAULT_COLOR_SCHEME.Surface
	frame.BackgroundTransparency = transparent or 0
	frame.BorderSizePixel = 0
	frame.ClipsDescendants = true
	frame.Parent = parent
	
	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 8)
	corner.Parent = frame
	
	return frame
end

-- Hiệu ứng tween
local function tweenObject(obj, properties, time, style)
	local tweenInfo = TweenInfo.new(time or DEFAULT_TWEEN_TIME, (style or Enum.EasingStyle.Quad), Enum.EasingDirection.Out)
	local tween = TweenService:Create(obj, tweenInfo, properties)
	tween:Play()
	return tween
end

-- ==================== CORE COMPONENTS ====================

-- Window (cửa sổ chính)
function UILibrary:NewWindow(title, size, closable)
	local screenGui = Instance.new("ScreenGui")
	screenGui.Name = "UILibrary_Gui"
	screenGui.ResetOnSpawn = false
	screenGui.Parent = game:GetService("CoreGui")
	
	local mainFrame = createStyledFrame(screenGui, "MainFrame", size or UDim2.fromScale(0.35, 0.5), UDim2.fromScale(0.5, 0.5), DEFAULT_COLOR_SCHEME.Background, 0)
	mainFrame.AnchorPoint = Vector2.new(0.5, 0.5)
	addShadow(mainFrame, 24, 0.5)
	
	-- Header với gradient
	local header = createStyledFrame(mainFrame, "Header", UDim2.fromScale(1, 0.1), UDim2.fromScale(0, 0), DEFAULT_COLOR_SCHEME.Primary, 0)
	applyGradient(header, DEFAULT_COLOR_SCHEME.Primary, DEFAULT_COLOR_SCHEME.PrimaryDark, "horizontal")
	
	local titleLabel = Instance.new("TextLabel")
	titleLabel.Name = "Title"
	titleLabel.Size = UDim2.fromScale(1, 1)
	titleLabel.Position = UDim2.fromScale(0, 0)
	titleLabel.BackgroundTransparency = 1
	titleLabel.Text = title or "UI Library"
	titleLabel.TextColor3 = DEFAULT_COLOR_SCHEME.Text
	titleLabel.TextScaled = false
	titleLabel.Font = Enum.Font.GothamBold
	titleLabel.TextSize = 18
	titleLabel.TextXAlignment = Enum.TextXAlignment.Left
	titleLabel.PaddingLeft = UDim.new(0, 15)
	titleLabel.Parent = header
	
	-- Close button (nếu có)
	local closeBtn = nil
	if closable then
		closeBtn = Instance.new("TextButton")
		closeBtn.Name = "CloseButton"
		closeBtn.Size = UDim2.fromOffset(30, 30)
		closeBtn.Position = UDim2.fromScale(1, 0.5)
		closeBtn.AnchorPoint = Vector2.new(1, 0.5)
		closeBtn.BackgroundTransparency = 1
		closeBtn.Text = "✕"
		closeBtn.TextColor3 = DEFAULT_COLOR_SCHEME.Text
		closeBtn.TextSize = 20
		closeBtn.Font = Enum.Font.GothamBold
		closeBtn.Parent = header
		
		closeBtn.MouseButton1Click:Connect(function()
			tweenObject(mainFrame, {BackgroundTransparency = 1}, 0.2)
			task.wait(0.2)
			screenGui:Destroy()
		end)
	end
	
	-- Content container
	local content = Instance.new("Frame")
	content.Name = "Content"
	content.Size = UDim2.fromScale(1, 0.9)
	content.Position = UDim2.fromScale(0, 0.1)
	content.BackgroundTransparency = 1
	content.Parent = mainFrame
	
	local contentList = Instance.new("UIListLayout")
	contentList.Padding = UDim.new(0, 10)
	contentList.HorizontalAlignment = Enum.HorizontalAlignment.Center
	contentList.SortOrder = Enum.SortOrder.LayoutOrder
	contentList.Parent = content
	
	local contentPadding = Instance.new("UIPadding")
	contentPadding.PaddingTop = UDim.new(0, 15)
	contentPadding.PaddingBottom = UDim.new(0, 15)
	contentPadding.PaddingLeft = UDim.new(0, 15)
	contentPadding.PaddingRight = UDim.new(0, 15)
	contentPadding.Parent = content
	
	-- Kéo thả window (PC + mobile)
	local dragging = false
	local dragStart, startPos
	
	local function inputBegan(input, isProcessed)
		if isProcessed then return end
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			local mousePos = UserInputService:GetMouseLocation()
			dragging = true
			dragStart = Vector2.new(mousePos.X, mousePos.Y)
			startPos = mainFrame.Position
		end
	end
	
	local function inputChanged(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local delta = UserInputService:GetMouseLocation() - dragStart
			local newPos = UDim2.fromOffset(startPos.X.Offset + delta.X, startPos.Y.Offset + delta.Y)
			mainFrame.Position = newPos
		end
	end
	
	local function inputEnded(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end
	
	header.InputBegan:Connect(inputBegan)
	UserInputService.InputChanged:Connect(inputChanged)
	UserInputService.InputEnded:Connect(inputEnded)
	
	return {
		Frame = mainFrame,
		Content = content,
		ContentList = contentList,
		Destroy = function() screenGui:Destroy() end
	}
end

-- Button (nút bấm đẹp)
function UILibrary:NewButton(parent, text, callback, layoutOrder)
	local btn = createStyledFrame(parent, "Button", UDim2.fromScale(1, 0.08), UDim2.fromScale(0, 0), DEFAULT_COLOR_SCHEME.SurfaceLight, 0)
	btn.LayoutOrder = layoutOrder or 1
	applyGradient(btn, DEFAULT_COLOR_SCHEME.SurfaceLight, DEFAULT_COLOR_SCHEME.Surface, "vertical")
	
	local textLabel = Instance.new("TextLabel")
	textLabel.Size = UDim2.fromScale(1, 1)
	textLabel.BackgroundTransparency = 1
	textLabel.Text = text
	textLabel.TextColor3 = DEFAULT_COLOR_SCHEME.Text
	textLabel.TextScaled = false
	textLabel.Font = Enum.Font.Gotham
	textLabel.TextSize = 16
	textLabel.Parent = btn
	
	local buttonScript = Instance.new("TextButton")
	buttonScript.Size = UDim2.fromScale(1, 1)
	buttonScript.BackgroundTransparency = 1
	buttonScript.Text = ""
	buttonScript.Parent = btn
	
	local function onHover()
		tweenObject(btn, {BackgroundColor3 = DEFAULT_COLOR_SCHEME.Primary}, 0.15)
		tweenObject(btn:FindFirstChildWhichIsA("UIGradient"), {Transparency = 0.2}, 0.15)
	end
	
	local function onLeave()
		tweenObject(btn, {BackgroundColor3 = DEFAULT_COLOR_SCHEME.SurfaceLight}, 0.15)
		tweenObject(btn:FindFirstChildWhichIsA("UIGradient"), {Transparency = 0}, 0.15)
	end
	
	local function onClick()
		tweenObject(btn, {BackgroundColor3 = DEFAULT_COLOR_SCHEME.PrimaryDark}, 0.05)
		task.wait(0.05)
		tweenObject(btn, {BackgroundColor3 = DEFAULT_COLOR_SCHEME.Primary}, 0.1)
		if callback then callback() end
	end
	
	if UserInputService.TouchEnabled then
		buttonScript.Activated:Connect(onClick)
	else
		buttonScript.MouseButton1Click:Connect(onClick)
		buttonScript.MouseEnter:Connect(onHover)
		buttonScript.MouseLeave:Connect(onLeave)
	end
	
	return btn
end

-- Toggle (công tắc bật/tắt)
function UILibrary:NewToggle(parent, text, defaultState, callback, layoutOrder)
	local container = createStyledFrame(parent, "ToggleContainer", UDim2.fromScale(1, 0.07), UDim2.fromScale(0, 0), DEFAULT_COLOR_SCHEME.Surface, 0)
	container.LayoutOrder = layoutOrder or 1
	
	local label = Instance.new("TextLabel")
	label.Size = UDim2.fromScale(0.7, 1)
	label.Position = UDim2.fromScale(0, 0)
	label.BackgroundTransparency = 1
	label.Text = text
	label.TextColor3 = DEFAULT_COLOR_SCHEME.Text
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.PaddingLeft = UDim.new(0, 12)
	label.Font = Enum.Font.Gotham
	label.TextSize = 16
	label.Parent = container
	
	local toggleBtn = Instance.new("Frame")
	toggleBtn.Size = UDim2.fromOffset(50, 26)
	toggleBtn.Position = UDim2.fromScale(1, 0.5)
	toggleBtn.AnchorPoint = Vector2.new(1, 0.5)
	toggleBtn.BackgroundColor3 = DEFAULT_COLOR_SCHEME.PrimaryDark
	toggleBtn.BorderSizePixel = 0
	toggleBtn.Parent = container
	
	local toggleCorner = Instance.new("UICorner")
	toggleCorner.CornerRadius = UDim.new(1, 0)
	toggleCorner.Parent = toggleBtn
	
	local knob = Instance.new("Frame")
	knob.Size = UDim2.fromOffset(22, 22)
	knob.Position = UDim2.fromOffset(2, 2)
	knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	knob.BorderSizePixel = 0
	knob.Parent = toggleBtn
	
	local knobCorner = Instance.new("UICorner")
	knobCorner.CornerRadius = UDim.new(1, 0)
	knobCorner.Parent = knob
	
	local state = defaultState or false
	local function updateToggle()
		local targetPos = state and UDim2.fromOffset(26, 2) or UDim2.fromOffset(2, 2)
		local bgColor = state and DEFAULT_COLOR_SCHEME.Primary or DEFAULT_COLOR_SCHEME.PrimaryDark
		tweenObject(knob, {Position = targetPos}, 0.15)
		tweenObject(toggleBtn, {BackgroundColor3 = bgColor}, 0.15)
		if callback then callback(state) end
	end
	
	local hitbox = Instance.new("TextButton")
	hitbox.Size = UDim2.fromScale(1, 1)
	hitbox.BackgroundTransparency = 1
	hitbox.Text = ""
	hitbox.Parent = container
	
	hitbox.MouseButton1Click:Connect(function()
		state = not state
		updateToggle()
	end)
	
	updateToggle()
	return container
end

-- Slider (thanh trượt giá trị)
function UILibrary:NewSlider(parent, text, min, max, default, callback, layoutOrder)
	local container = createStyledFrame(parent, "SliderContainer", UDim2.fromScale(1, 0.1), UDim2.fromScale(0, 0), DEFAULT_COLOR_SCHEME.Surface, 0)
	container.LayoutOrder = layoutOrder or 1
	
	local label = Instance.new("TextLabel")
	label.Size = UDim2.fromScale(1, 0.4)
	label.Position = UDim2.fromScale(0, 0)
	label.BackgroundTransparency = 1
	label.Text = text .. ": " .. tostring(default)
	label.TextColor3 = DEFAULT_COLOR_SCHEME.Text
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.Font = Enum.Font.Gotham
	label.TextSize = 14
	label.Parent = container
	
	local sliderBar = Instance.new("Frame")
	sliderBar.Size = UDim2.fromScale(1, 0.3)
	sliderBar.Position = UDim2.fromScale(0, 0.6)
	sliderBar.BackgroundColor3 = DEFAULT_COLOR_SCHEME.Background
	sliderBar.BorderSizePixel = 0
	sliderBar.Parent = container
	
	local fill = Instance.new("Frame")
	fill.Size = UDim2.fromScale(0.5, 1)
	fill.BackgroundColor3 = DEFAULT_COLOR_SCHEME.Primary
	fill.BorderSizePixel = 0
	fill.Parent = sliderBar
	
	local sliderCorner = Instance.new("UICorner")
	sliderCorner.CornerRadius = UDim.new(1, 0)
	sliderCorner.Parent = sliderBar
	fill.CornerRadius = UDim.new(1, 0)
	
	local knob = Instance.new("Frame")
	knob.Size = UDim2.fromOffset(16, 16)
	knob.Position = UDim2.fromScale(0.5, 0.5)
	knob.AnchorPoint = Vector2.new(0.5, 0.5)
	knob.BackgroundColor3 = DEFAULT_COLOR_SCHEME.Text
	knob.BorderSizePixel = 0
	knob.Parent = sliderBar
	Instance.new("UICorner").CornerRadius = UDim.new(1, 0)
	
	local value = default or min
	local function setValueFromPosition(mouseX)
		local barWidth = sliderBar.AbsoluteSize.X
		local percent = math.clamp((mouseX - sliderBar.AbsolutePosition.X) / barWidth, 0, 1)
		value = min + (max - min) * percent
		value = math.floor(value * 100) / 100
		fill.Size = UDim2.fromScale(percent, 1)
		knob.Position = UDim2.fromScale(percent, 0.5)
		label.Text = text .. ": " .. tostring(value)
		if callback then callback(value) end
	end
	
	local dragging = false
	local function onInputBegan(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			setValueFromPosition(UserInputService:GetMouseLocation().X)
		end
	end
	
	local function onInputChanged(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			setValueFromPosition(UserInputService:GetMouseLocation().X)
		end
	end
	
	local function onInputEnded(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end
	
	sliderBar.InputBegan:Connect(onInputBegan)
	UserInputService.InputChanged:Connect(onInputChanged)
	UserInputService.InputEnded:Connect(onInputEnded)
	
	return container
end

-- TextBox (ô nhập liệu)
function UILibrary:NewTextBox(parent, placeholder, callback, layoutOrder)
	local container = createStyledFrame(parent, "TextBoxContainer", UDim2.fromScale(1, 0.08), UDim2.fromScale(0, 0), DEFAULT_COLOR_SCHEME.Background, 0)
	container.LayoutOrder = layoutOrder or 1
	
	local box = Instance.new("TextBox")
	box.Size = UDim2.fromScale(1, 1)
	box.Position = UDim2.fromScale(0, 0)
	box.BackgroundTransparency = 1
	box.PlaceholderText = placeholder or "Nhập nội dung..."
	box.Text = ""
	box.TextColor3 = DEFAULT_COLOR_SCHEME.Text
	box.PlaceholderColor3 = DEFAULT_COLOR_SCHEME.TextSecondary
	box.Font = Enum.Font.Gotham
	box.TextSize = 16
	box.TextXAlignment = Enum.TextXAlignment.Left
	box.PaddingLeft = UDim.new(0, 12)
	box.Parent = container
	
	box.FocusLost:Connect(function(enterPressed)
		if callback then callback(box.Text) end
	end)
	
	return container
end

