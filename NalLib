-- ==================== DROPDOWN ====================
function UILibrary:NewDropdown(parent, placeholder, options, defaultOption, callback, layoutOrder)
	local container = createStyledFrame(parent, "DropdownContainer", UDim2.fromScale(1, 0.07), UDim2.fromScale(0, 0), DEFAULT_COLOR_SCHEME.Surface, 0)
	container.LayoutOrder = layoutOrder or 1
	container.ClipsDescendants = false -- để list có thể đổ ra ngoài
	
	local mainButton = Instance.new("TextButton")
	mainButton.Name = "MainButton"
	mainButton.Size = UDim2.fromScale(1, 1)
	mainButton.BackgroundTransparency = 1
	mainButton.Text = ""
	mainButton.AutoButtonColor = false
	mainButton.Parent = container
	
	local selectedText = Instance.new("TextLabel")
	selectedText.Size = UDim2.fromScale(0.85, 1)
	selectedText.Position = UDim2.fromScale(0, 0)
	selectedText.BackgroundTransparency = 1
	selectedText.Text = placeholder or "Chọn một mục"
	selectedText.TextColor3 = DEFAULT_COLOR_SCHEME.Text
	selectedText.TextXAlignment = Enum.TextXAlignment.Left
	selectedText.PaddingLeft = UDim.new(0, 12)
	selectedText.Font = Enum.Font.Gotham
	selectedText.TextSize = 16
	selectedText.TextTruncate = Enum.TextTruncate.AtEnd
	selectedText.Parent = container
	
	local arrow = Instance.new("TextLabel")
	arrow.Size = UDim2.fromOffset(24, 24)
	arrow.Position = UDim2.fromScale(1, 0.5)
	arrow.AnchorPoint = Vector2.new(1, 0.5)
	arrow.BackgroundTransparency = 1
	arrow.Text = "▼"
	arrow.TextColor3 = DEFAULT_COLOR_SCHEME.TextSecondary
	arrow.TextSize = 18
	arrow.Font = Enum.Font.Gotham
	arrow.Parent = container
	
	-- Dropdown list (ẩn ban đầu)
	local listFrame = createStyledFrame(container, "DropdownList", UDim2.fromScale(1, 0), UDim2.fromScale(0, 1), DEFAULT_COLOR_SCHEME.SurfaceLight, 0)
	listFrame.Visible = false
	listFrame.ClipsDescendants = true
	listFrame.AutomaticSize = Enum.AutomaticSize.Y
	listFrame.ZIndex = 10
	addShadow(listFrame, 12, 0.4)
	
	local listLayout = Instance.new("UIListLayout")
	listLayout.Padding = UDim.new(0, 2)
	listLayout.SortOrder = Enum.SortOrder.LayoutOrder
	listLayout.Parent = listFrame
	
	-- Tạo các option
	local optionButtons = {}
	local selectedValue = defaultOption or (options[1] or "")
	
	local function updateSelectedText(value)
		selectedText.Text = value
		if callback then callback(value) end
	end
	
	local function closeDropdown()
		if not listFrame.Visible then return end
		tweenObject(listFrame, {Size = UDim2.fromScale(1, 0)}, 0.15)
		task.wait(0.12)
		listFrame.Visible = false
	end
	
	local function openDropdown()
		if listFrame.Visible then
			closeDropdown()
			return
		end
		listFrame.Visible = true
		local totalHeight = #options * 32 + (#options - 1) * 2 + 10 -- mỗi option cao 32, padding 2, thêm 10 padding trên dưới
		local targetHeight = math.min(totalHeight, 200)
		listFrame.Size = UDim2.fromScale(1, 0)
		tweenObject(listFrame, {Size = UDim2.fromScale(1, 0, targetHeight / container.AbsoluteSize.Y)}, 0.2)
	end
	
	-- Tạo từng option
	for idx, option in ipairs(options) do
		local btn = createStyledFrame(listFrame, "Option_" .. tostring(idx), UDim2.fromScale(1, 0), UDim2.fromScale(0, 0), DEFAULT_COLOR_SCHEME.Surface, 0)
		btn.AutomaticSize = Enum.AutomaticSize.Y
		btn.LayoutOrder = idx
		
		local btnText = Instance.new("TextLabel")
		btnText.Size = UDim2.fromScale(1, 0)
		btnText.AutomaticSize = Enum.AutomaticSize.Y
		btnText.BackgroundTransparency = 1
		btnText.Text = option
		btnText.TextColor3 = DEFAULT_COLOR_SCHEME.Text
		btnText.TextXAlignment = Enum.TextXAlignment.Left
		btnText.PaddingLeft = UDim.new(0, 12)
		btnText.Font = Enum.Font.Gotham
		btnText.TextSize = 15
		btnText.Parent = btn
		
		local btnHitbox = Instance.new("TextButton")
		btnHitbox.Size = UDim2.fromScale(1, 1)
		btnHitbox.BackgroundTransparency = 1
		btnHitbox.Text = ""
		btnHitbox.Parent = btn
		
		-- Hover & click
		local function onHover()
			tweenObject(btn, {BackgroundColor3 = DEFAULT_COLOR_SCHEME.Primary}, 0.1)
		end
		local function onLeave()
			tweenObject(btn, {BackgroundColor3 = DEFAULT_COLOR_SCHEME.Surface}, 0.1)
		end
		local function onClick()
			selectedValue = option
			updateSelectedText(option)
			closeDropdown()
		end
		
		if UserInputService.TouchEnabled then
			btnHitbox.Activated:Connect(onClick)
		else
			btnHitbox.MouseEnter:Connect(onHover)
			btnHitbox.MouseLeave:Connect(onLeave)
			btnHitbox.MouseButton1Click:Connect(onClick)
		end
		
		table.insert(optionButtons, btn)
	end
	
	-- Xử lý mở/đóng dropdown
	local function onMainClick()
		openDropdown()
	end
	
	if UserInputService.TouchEnabled then
		mainButton.Activated:Connect(onMainClick)
	else
		mainButton.MouseButton1Click:Connect(onMainClick)
	end
	
	-- Đóng dropdown khi click ra ngoài (global)
	local function onGlobalClick(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			local mousePos = UserInputService:GetMouseLocation()
			local listAbsPos = listFrame.AbsolutePosition
			local listAbsSize = listFrame.AbsoluteSize
			if listFrame.Visible then
				if mousePos.X < listAbsPos.X or mousePos.X > listAbsPos.X + listAbsSize.X or
				   mousePos.Y < listAbsPos.Y or mousePos.Y > listAbsPos.Y + listAbsSize.Y then
					closeDropdown()
				end
			end
		end
	end
	UserInputService.InputBegan:Connect(onGlobalClick)
	
	-- Khởi tạo giá trị mặc định
	if defaultOption then
		selectedText.Text = defaultOption
	end
	
	return container
end

return UILibrary
