	label.BackgroundTransparency = 1
	label.Text = text or ""
	label.TextColor3 = textColor or DEFAULT_COLOR_SCHEME.TextSecondary
	label.TextScaled = false
	label.Font = Enum.Font.Gotham
	label.TextSize = textSize or 14
	label.TextWrapped = true
